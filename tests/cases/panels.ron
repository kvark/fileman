(
  root: "tests/data/basic",
  right: Some("tests/data/basic"),
  keys: [
    (key: "Wait"),
    // --- Panel switching (Tab) ---
    // Move down on left panel
    (key: "Down"),
    (key: "Down"),
    // Switch to right panel
    (key: "Tab"),
    // Move down once on right panel
    (key: "Down"),
    // Switch back to left panel
    (key: "Tab"),

    // --- Panel swap (Ctrl+U) ---
    (key: "U", modifiers: ["Ctrl"]),
    // After swap: left panel has right's state (cursor on "out"),
    //             right panel has left's state (cursor on "binary.bin")

    // --- Cross-panel navigation (Ctrl+Right) ---
    // Left panel now has "out" selected. Open it in right panel.
    (key: "Right", modifiers: ["Ctrl"]),
    (key: "Wait"),
  ],
  asserts: (
    // Left panel: was right before swap, had cursor on "out"
    left_panel: Some((
      selected: Some("out"),
      panel_mode: Some("Browser"),
      browser_mode: Some("Fs"),
    )),
    // Right panel: Ctrl+Right opened "out" dir, so it's inside out/
    right_panel: Some((
      mode: Contains,
      entries: [".."],
      panel_mode: Some("Browser"),
      browser_mode: Some("Fs"),
    )),
  ),
)
