(
  root: "tests/data/basic",
  keys: [
    (key: "Wait"),
    // Navigate into "out" directory (to avoid modifying shared test data)
    (key: "select:out"),
    (key: "Enter"),
    (key: "Wait"),
    // Create a new file first
    (key: "F4", modifiers: ["Shift"]),
    (key: "replace:edit_test.txt"),
    (key: "Enter"),
    (key: "Wait"),
    // Now open it in editor with F4
    (key: "select:edit_test.txt"),
    (key: "F4"),
    (key: "Wait"),
    // Type some text
    (key: "text:Hello World"),
    // Save with Ctrl+S
    (key: "S", modifiers: ["Ctrl"]),
    (key: "Wait"),
  ],
  asserts: (
    files: [
      (path: "out/edit_test.txt", contains: Some("Hello World")),
    ],
  ),
)
