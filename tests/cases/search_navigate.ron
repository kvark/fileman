(
  root: "tests/data/basic",
  keys: [
    (key: "Wait"),
    // --- Search by content (Shift+Alt+F7) ---
    (key: "F7", modifiers: ["Shift", "Alt"]),
    (key: "text:sample text"),
    (key: "Enter"),
    (key: "Wait"),
  ],
  asserts: (
    // Content search should find source.txt
    left_panel: Some((
      mode: Contains,
      entries: ["source.txt"],
      browser_mode: Some("Search"),
      panel_mode: Some("Browser"),
    )),
  ),
)
