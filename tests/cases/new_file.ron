(
  root: "tests/data/basic",
  keys: [
    (key: "Wait"),
    // Navigate into "out" directory
    (key: "select:out"),
    (key: "Enter"),
    (key: "Wait"),
    // Create a new file with Shift+F4
    (key: "F4", modifiers: ["Shift"]),
    // Replace the default name
    (key: "replace:test_new_file.txt"),
    (key: "Enter"),
    (key: "Wait"),
  ],
  asserts: (
    fs: Some((
      mode: Contains,
      entries: [
        (path: "out/test_new_file.txt", kind: File),
      ],
    )),
    left_panel: Some((
      mode: Contains,
      entries: ["test_new_file.txt"],
      browser_mode: Some("Fs"),
      selected: Some("test_new_file.txt"),
    )),
  ),
)
