(
  root: "tests/data/basic",
  keys: [
    (key: "Wait"),
    // Start at top, move to end
    (key: "End"),
    // Now at last entry (source.txt)
    // PageUp should bring us back towards top
    (key: "PageUp"),
  ],
  asserts: (
    left_panel: Some((
      // After End then PageUp, cursor should be at or near top
      // With 4 entries (.., out, binary.bin, source.txt), PageUp from end
      // should land at ".." (index 0) since page size > entry count
      selected: Some(".."),
      panel_mode: Some("Browser"),
    )),
  ),
)
