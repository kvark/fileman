(
  root: "tests/data/basic",
  keys: [
    (key: "Wait"),
    // Open help screen
    (key: "F1"),
    // Verify help is open, then close with Escape
    (key: "Escape"),
  ],
  asserts: (
    // Both panels should be back in Browser mode after Escape
    left_panel: Some((
      panel_mode: Some("Browser"),
    )),
    right_panel: Some((
      panel_mode: Some("Browser"),
    )),
  ),
)
