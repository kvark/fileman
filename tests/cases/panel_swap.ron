(
  root: "tests/data/basic",
  right: Some("tests/data/basic"),
  keys: [
    (key: "Wait"),
    // Move cursor down twice on left panel (to binary.bin)
    (key: "Down"),
    (key: "Down"),
    // Switch to right panel
    (key: "Tab"),
    // Move cursor down once on right panel (to out)
    (key: "Down"),
    // Switch back to left panel
    (key: "Tab"),
    // Swap panels with Ctrl+U
    (key: "U", modifiers: ["Ctrl"]),
  ],
  asserts: (
    // After swap, the left panel should have what was in right (cursor on "out")
    left_panel: Some((
      selected: Some("out"),
      panel_mode: Some("Browser"),
    )),
    // The right panel should have what was in left (cursor on "binary.bin")
    right_panel: Some((
      selected: Some("binary.bin"),
      panel_mode: Some("Browser"),
    )),
  ),
)
