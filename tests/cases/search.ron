(
  root: "tests/data/basic",
  keys: [
    (key: "Wait"),
    // --- Search by filename (Alt+F7) ---
    (key: "F7", modifiers: ["Alt"]),
    (key: "text:source"),
    (key: "Enter"),
    (key: "Wait"),
    // Escape should return to original directory listing
    (key: "Escape"),
    (key: "Wait"),
  ],
  asserts: (
    // Verify no spurious new_dir was created by F7 leaking through
    fs: Some((
      mode: Contains,
      entries: [
        (path: "out", kind: Dir),
        (path: "source.txt", kind: File),
        (path: "binary.bin", kind: File),
      ],
    )),
    // Verify Escape restored original directory with no spurious entries
    left_panel: Some((
      mode: Contains,
      entries: ["..", "out", "binary.bin", "source.txt"],
      browser_mode: Some("Fs"),
      panel_mode: Some("Browser"),
    )),
  ),
)
