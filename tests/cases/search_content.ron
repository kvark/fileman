(
  root: "tests/data/basic",
  keys: [
    (key: "Wait"),
    // Open content search dialog with Shift+Alt+F7
    (key: "F7", modifiers: ["Shift", "Alt"]),
    // Type search query (text that exists in source.txt)
    (key: "text:sample text"),
    // Start search
    (key: "Enter"),
    // Wait for search results
    (key: "Wait"),
  ],
  asserts: (
    left_panel: Some((
      mode: Contains,
      entries: ["source.txt"],
      browser_mode: Some("Search"),
      panel_mode: Some("Browser"),
    )),
  ),
)
