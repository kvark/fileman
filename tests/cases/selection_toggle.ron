(
  root: "tests/data/basic",
  keys: [
    (key: "Wait"),
    // Move to "out" entry
    (key: "Down"),
    // Mark "out" with Insert (Insert marks + moves down)
    (key: "Insert"),
    // Now on "binary.bin", go back up to "out"
    (key: "Up"),
    // Unmark "out" with Insert again
    (key: "Insert"),
    // Now on "binary.bin" with "out" unmarked
  ],
  asserts: (
    left_panel: Some((
      // After toggle, "out" should no longer be marked
      selected: Some("binary.bin"),
      marked: [],
    )),
  ),
)
